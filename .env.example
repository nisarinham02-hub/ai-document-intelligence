# ============================================
# AI DOCUMENT INTELLIGENCE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control

# ============================================
# GOOGLE GEMINI API
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use for generation
GEMINI_MODEL=gemini-pro

# Model to use for embeddings
GEMINI_EMBEDDING_MODEL=embedding-001

# Temperature for responses (0-1, lower = more deterministic)
GEMINI_TEMPERATURE=0.7

# Maximum tokens per response
GEMINI_MAX_TOKENS=1024

# ============================================
# QDRANT VECTOR DATABASE
# ============================================
# Local Qdrant URL (default)
QDRANT_URL=http://localhost:6333

# Qdrant Cloud URL (if using cloud)
# QDRANT_URL=https://your-cluster.qdrant.io

# Qdrant API Key (optional, required for cloud)
QDRANT_API_KEY=optional_qdrant_api_key

# Qdrant collection name for documents
QDRANT_COLLECTION_NAME=documents

# Vector dimension size (Gemini embedding size)
VECTOR_DIMENSION=768

# Similarity threshold for search (0-1)
SIMILARITY_THRESHOLD=0.7

# Maximum search results
MAX_SEARCH_RESULTS=5

# ============================================
# N8N WORKFLOW
# ============================================
# Your n8n instance URL
N8N_BASE_URL=http://localhost:5678

# Webhook URL for PDF upload
N8N_WEBHOOK_URL=http://localhost:5678/webhook/upload-pdf

# Webhook URL for chat queries
N8N_CHAT_WEBHOOK_URL=http://localhost:5678/webhook/chat-query

# N8N API Key (if needed)
N8N_API_KEY=your_n8n_api_key_here

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Frontend base URL (for CORS)
FRONTEND_URL=http://localhost:8000

# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# Chunk size for text splitting (characters)
CHUNK_SIZE=1000

# Overlap between chunks (characters)
CHUNK_OVERLAP=200

# Maximum messages to display in chat
MAX_MESSAGES_DISPLAY=100

# Auto-save chat history interval (milliseconds)
AUTO_SAVE_INTERVAL=5000

# ============================================
# PDF PROCESSING
# ============================================
# Enable PDF text extraction
ENABLE_PDF_EXTRACTION=true

# Enable OCR for scanned PDFs (requires OCR service)
ENABLE_OCR=false

# OCR service endpoint (if enabled)
OCR_SERVICE_URL=http://localhost:8080/ocr

# Preserve PDF formatting
PRESERVE_FORMATTING=true

# ============================================
# VECTOR SEARCH SETTINGS
# ============================================
# Use RAG (Retrieval-Augmented Generation)
USE_RAG=true

# Rerank results using cross-encoder
USE_RERANKING=false

# Reranking model (if enabled)
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# Minimum score for reranked results
MIN_RERANK_SCORE=0.5

# ============================================
# CACHING
# ============================================
# Enable response caching
ENABLE_CACHE=true

# Cache duration in seconds
CACHE_DURATION=3600

# Cache type (memory, redis, none)
CACHE_TYPE=memory

# Redis URL (if using Redis cache)
REDIS_URL=redis://localhost:6379

# ============================================
# RATE LIMITING
# ============================================
# Enable rate limiting
ENABLE_RATE_LIMIT=true

# Requests per minute per IP
RATE_LIMIT_RPM=60

# Burst limit
RATE_LIMIT_BURST=10

# ============================================
# LOGGING
# ============================================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable file logging
ENABLE_FILE_LOGGING=true

# Log file path
LOG_FILE_PATH=./logs/app.log

# Max log file size in MB
LOG_MAX_SIZE=10

# Number of log files to keep
LOG_MAX_FILES=5

# ============================================
# SECURITY
# ============================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Enable HTTPS only
HTTPS_ONLY=false

# Session timeout in minutes
SESSION_TIMEOUT=60

# Enable input sanitization
ENABLE_SANITIZATION=true

# ============================================
# DATABASE (Optional)
# ============================================
# For storing chat history, user data, etc.
# Database type (mongodb, postgresql, none)
DB_TYPE=none

# MongoDB connection string
# MONGODB_URI=mongodb://localhost:27017/ai-document-intelligence

# PostgreSQL connection string
# POSTGRES_URI=postgresql://user:password@localhost:5432/ai-document-intelligence

# ============================================
# EXTERNAL SERVICES
# ============================================
# Sentry for error tracking (optional)
SENTRY_DSN=

# Google Analytics ID (optional)
GA_ID=

# Amplitude API Key (optional)
AMPLITUDE_API_KEY=

# ============================================
# DEVELOPMENT
# ============================================
# Environment (development, production, staging)
NODE_ENV=development

# Enable debug mode
DEBUG=false

# Enable hot reload
HOT_RELOAD=true

# API response delay simulation (ms, for testing)
SIMULATE_DELAY=0

# ============================================
# PRODUCTION SETTINGS
# ============================================
# Use only when deploying to production

# Production API base URL
PRODUCTION_API_URL=https://your-production-domain.com/api

# Production Gemini API Key (different from dev)
PRODUCTION_GEMINI_API_KEY=

# Production Qdrant URL
PRODUCTION_QDRANT_URL=https://your-production-qdrant.qdrant.io

# Production n8n URL
PRODUCTION_N8N_URL=https://your-production-n8n.example.com

# ============================================
# CUSTOM SETTINGS
# ============================================
# Add any custom settings below
# APP_NAME=AI Document Intelligence
# APP_VERSION=1.0.0
# SUPPORT_EMAIL=support@example.com
