{
  "name": "ai-document-intelligence",
  "version": "1.0.0",
  "description": "ChatPDF-like AI Document Intelligence web application with Gemini API and RAG",
  "main": "index.html",
  "type": "module",
  "scripts": {
    "start": "http-server . -p 8000",
    "dev": "http-server . -p 8000 -c-1",
    "serve": "python -m http.server 8000",
    "build": "echo 'No build step needed for static files'",
    "test": "jest",
    "lint": "eslint *.js",
    "lint:fix": "eslint *.js --fix",
    "format": "prettier --write '**/*.{js,html,css,json}'",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "setup": "node scripts/setup.js"
  },
  "keywords": [
    "ai",
    "document",
    "intelligence",
    "chatpdf",
    "gemini",
    "rag",
    "vector-database",
    "n8n",
    "qdrant"
  ],
  "author": "Nisar",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1",
    "dotenv": "^16.3.1",
    "axios": "^1.4.0",
    "uuid": "^9.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nisarinham02-hub/ai-document-intelligence.git"
  },
  "bugs": {
    "url": "https://github.com/nisarinham02-hub/ai-document-intelligence/issues"
  },
  "homepage": "https://github.com/nisarinham02-hub/ai-document-intelligence#readme"
}
